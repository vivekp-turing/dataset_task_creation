# Provider API keys. Set the one(s) matching your chosen PydanticAI model string.
# Auto-QC's default two judges need BOTH of the first two below:
#   ANTHROPIC_API_KEY  -> opus judge  (anthropic:claude-opus-4-8)
#   OPENROUTER_API_KEY -> kimi judge  (openrouter:moonshotai/kimi-k2.7-code)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Default single model used when `uv run annotate-one` is called directly
# (no --model). The auto_qc.py orchestrator overrides these per judge.
ANNOTATION_MODEL=anthropic:claude-sonnet-5
EXTRACTOR_MODEL=anthropic:claude-sonnet-5

# Default local output directory.
ANNOTATION_OUTPUT_DIR=output/ai_annotation

# Optional Google Sheets sync.
# Credentials path is hardcoded in src/swebench_like_gen/cli.py.
QUALITY_FILE_ID=
QUALITY_SHEETS_NAME=
QUALITY_LIST_SHEET_NAME=
